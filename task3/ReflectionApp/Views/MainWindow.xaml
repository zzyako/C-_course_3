<Window x:Class="ReflectionApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Инспектор классов через рефлексию"
        Height="720" Width="1100"
        MinHeight="600" MinWidth="900">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Инспектор классов через рефлексию"
                   FontSize="20" FontWeight="Bold"
                   Margin="0,0,0,12"/>

        <!-- Строка загрузки библиотеки -->
        <Border Grid.Row="1"
                BorderBrush="#CCCCCC" BorderThickness="1"
                CornerRadius="4" Padding="10" Margin="0,0,0,10"
                Background="#FAFAFA">
            <StackPanel>
                <TextBlock Text="Библиотека классов" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="PathTextBox"
                             Grid.Column="0"
                             Padding="6,4" FontSize="13"
                             Margin="0,0,8,0"
                             TextChanged="PathTextBox_TextChanged"/>

                    <Button Grid.Column="1"
                            Content="Обзор…"
                            Padding="12,6" Margin="0,0,8,0"
                            Click="BrowseButton_Click"/>

                    <Button x:Name="LoadButton"
                            Grid.Column="2"
                            Content="Загрузить"
                            Padding="14,6"
                            Background="#0078D4" Foreground="White"
                            BorderThickness="0"
                            Click="LoadButton_Click"/>
                </Grid>

                <TextBlock x:Name="StatusText"
                           FontSize="12" Foreground="#555555"
                           Margin="0,8,0,0" TextWrapping="Wrap"
                           Text="Укажите путь к библиотеке классов и нажмите «Загрузить»."/>
            </StackPanel>
        </Border>

        <!-- Основная область -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <!-- Классы -->
            <Border Grid.Column="0"
                    BorderBrush="#CCCCCC" BorderThickness="1"
                    CornerRadius="4" Padding="10" Background="#FAFAFA">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Классы"
                               FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <ListBox x:Name="ClassListBox"
                             BorderThickness="0" Background="Transparent"
                             FontSize="13"
                             SelectionChanged="ClassListBox_SelectionChanged"/>
                </DockPanel>
            </Border>

            <!-- Методы + параметры -->
            <Border Grid.Column="2"
                    BorderBrush="#CCCCCC" BorderThickness="1"
                    CornerRadius="4" Padding="10" Background="#FAFAFA">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Методы класса"
                               FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ListBox x:Name="MethodListBox"
                                 Grid.Row="0"
                                 FontFamily="Consolas" FontSize="12"
                                 BorderThickness="1" BorderBrush="#DDDDDD"
                                 SelectionChanged="MethodListBox_SelectionChanged"/>

                        <Border Grid.Row="2"
                                BorderBrush="#DDDDDD" BorderThickness="1"
                                CornerRadius="3" Padding="8" Background="#F5F5F5">
                            <StackPanel>
                                <TextBlock Text="Параметры метода"
                                           FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <ItemsControl x:Name="ParametersPanel"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </DockPanel>
            </Border>

            <!-- Результат -->
            <Border Grid.Column="4"
                    BorderBrush="#CCCCCC" BorderThickness="1"
                    CornerRadius="4" Padding="10" Background="#FAFAFA">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Результат выполнения"
                               FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <Button x:Name="ExecuteButton"
                            DockPanel.Dock="Bottom"
                            Content="▶  Выполнить"
                            Background="#0078D4" Foreground="White"
                            BorderThickness="0" Padding="14,6"
                            Margin="0,8,0,0"
                            IsEnabled="False"
                            Click="ExecuteButton_Click"/>
                    <TextBox x:Name="ResultText"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas" FontSize="12"
                             Background="White" BorderBrush="#DDDDDD"
                             Padding="6" AcceptsReturn="True"/>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Статусная строка -->
        <Border Grid.Row="3"
                Background="#F0F0F0" BorderBrush="#CCCCCC"
                BorderThickness="0,1,0,0" Padding="8,4"
                Margin="-15,8,-15,-15">
            <TextBlock x:Name="FooterText" FontSize="11" Foreground="#666666"
                       Text="Выбранный класс: —  |  Базовый тип: —"/>
        </Border>
    </Grid>
</Window>
